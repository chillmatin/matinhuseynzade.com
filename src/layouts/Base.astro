---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

import Themes from "astro-themes";
import { ViewTransitions } from "astro:transitions";

import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/600.css";
import "@styles/global.css";
import lenisScriptUrl from "@scripts/lenisSmoothScroll.js?url";

const { title, description, image } = Astro.props;
---

<html lang="en" class="scrollbar-hide lenis lenis-smooth">
  <head>
    <ViewTransitions />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="googlebot"
      content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Themes />
    <BaseHead title={title} description={description} image={image} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Matin Huseynzade's RSS Feed"
      href={new URL("rss.xml", Astro.site)}
    />
    <script type="module" define:vars={{ lenisScriptUrl }}>
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      const loadLenis = () =>
        import(lenisScriptUrl).then((m) => (m.initLenis || m.default)?.());

      if (!prefersReduced.matches) {
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadLenis);
        } else {
          setTimeout(loadLenis, 0);
        }
      }

      prefersReduced.addEventListener("change", (event) => {
        if (!event.matches) loadLenis();
      });
    </script>
    <script is:inline>
      // Reset global gallery on navigation to prevent image accumulation
      document.addEventListener("astro:page-load", () => {
        if (typeof window !== "undefined" && window.__globalGallery) {
          window.__globalGallery.reset();
        }
      });
    </script>
  </head>
  <body
    class="antialiased min-h-screen flex flex-col items-center mx-auto pt-2 lg:pt-8 pb-20 lg:pb-40
    scrollbar-hide">
    <main
      class="flex-1 min-w-0 mt-2 md:mt-6 flex flex-col px-6 sm:px-4 md:px-0 max-w-[640px] w-full">
      <Navbar />
      <slot />
      <Footer />
    </main>
    <style>
      /* CSS rules for the page scrollbar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </body>
</html>
