---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

import BaseHead from "../components/BaseHead.astro";
import Analytics from "../components/Analytics.astro";
import Navbar from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/600.css";
import "@styles/global.css";

const { title, description, image } = Astro.props;
---

<html lang="en" class="scrollbar-hide">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="googlebot"
      content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      const themeStorageKey = "theme";
      const systemThemeQuery = window.matchMedia("(prefers-color-scheme: dark)");

      const getStoredTheme = () => localStorage.getItem(themeStorageKey);
      const resolveTheme = (storedTheme) => {
        if (storedTheme === "light" || storedTheme === "dark") {
          return storedTheme;
        }

        return systemThemeQuery.matches ? "dark" : "light";
      };

      const applyTheme = (theme, preference) => {
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-theme-preference", preference ?? "");
        document.documentElement.style.colorScheme = theme;
      };

      const syncThemeFromStorage = () => {
        const storedTheme = getStoredTheme();
        applyTheme(resolveTheme(storedTheme), storedTheme);
      };

      document.addEventListener("set-theme", (event) => {
        const requestedTheme = event.detail;

        if (requestedTheme === "light" || requestedTheme === "dark") {
          localStorage.setItem(themeStorageKey, requestedTheme);
          applyTheme(requestedTheme, requestedTheme);
        } else {
          localStorage.removeItem(themeStorageKey);
          syncThemeFromStorage();
        }
      });

      window.addEventListener("storage", (event) => {
        if (event.key === themeStorageKey) {
          syncThemeFromStorage();
        }
      });

      systemThemeQuery.addEventListener("change", syncThemeFromStorage);
      document.addEventListener("astro:after-swap", syncThemeFromStorage);
      syncThemeFromStorage();
    </script>
    <BaseHead title={title} description={description} image={image} />
    <Analytics />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Matin Huseynzade's RSS Feed"
      href={new URL("rss.xml", Astro.site)}
    />
    <script is:inline>
      const resetGlobalGallery = () => {
        if (typeof window !== "undefined" && window.__globalGallery) {
          window.__globalGallery.reset();
        }
      };

      resetGlobalGallery();
      document.addEventListener("DOMContentLoaded", resetGlobalGallery, { once: true });
    </script>
  </head>
  <body
    class="antialiased min-h-screen flex flex-col items-center mx-auto pt-2 lg:pt-8 pb-20 lg:pb-40
    scrollbar-hide">
    <main
      class="flex-1 min-w-0 mt-2 md:mt-6 flex flex-col px-6 sm:px-4 md:px-0 max-w-[640px] w-full">
      <Navbar />
      <slot />
      <Footer />
    </main>
    <button
      id="scroll-to-top"
      aria-label="Scroll to top"
      class="fixed bottom-8 right-8 z-50 flex items-center justify-center
             w-9 h-9 rounded-full border border-neutral-300 dark:border-neutral-700
             bg-white/80 dark:bg-neutral-900/80 backdrop-blur-sm
             text-neutral-600 dark:text-neutral-400
             shadow-sm hover:shadow-md
             opacity-0 pointer-events-none
             transition-all duration-300 ease-in-out
             hover:scale-110 hover:text-neutral-900 dark:hover:text-neutral-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script is:inline>
      const bindScrollToTop = () => {
        const btn = document.getElementById("scroll-to-top");
        const nav = document.querySelector("nav");
        if (!btn || !nav) return;

        const observer = new IntersectionObserver(
          ([entry]) => {
            if (!entry.isIntersecting) {
              btn.classList.remove("opacity-0", "pointer-events-none");
              btn.classList.add("opacity-100", "pointer-events-auto");
            } else {
              btn.classList.add("opacity-0", "pointer-events-none");
              btn.classList.remove("opacity-100", "pointer-events-auto");
            }
          },
          { threshold: 0 }
        );

        observer.observe(nav);

        btn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      };

      bindScrollToTop();
      document.addEventListener("DOMContentLoaded", bindScrollToTop, { once: true });
    </script>

    <style>
      /* CSS rules for the page scrollbar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </body>
</html>
