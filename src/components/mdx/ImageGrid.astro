---
import { Image } from "astro:assets";
import LightboxGallery from "./LightboxGallery";

interface ImageGridProps {
  images: {
    src: string;
    alt: string;
    href?: string;
  }[];
  columns?: 2 | 3 | 4;
  lightbox?: boolean;
}

const { images, columns = 3, lightbox = false } = Astro.props as ImageGridProps;

const gridClass = {
  2: "grid-cols-2 sm:grid-cols-2",
  3: "grid-cols-2 sm:grid-cols-3",
  4: "grid-cols-2 sm:grid-cols-4",
}[columns];
---

<section>
  {
    lightbox ? (
      <LightboxGallery images={images} columns={columns} client:idle />
    ) : (
      <div class={`grid ${gridClass} gap-4 my-8`}>
        {images.map((image) => (
          <div class="relative aspect-square">
            {image.href ? (
              <a
                target="_blank"
                rel="noopener noreferrer"
                href={image.href}
                class="block w-full h-full">
                <Image
                  alt={image.alt}
                  src={image.src}
                  width={500}
                  height={500}
                  loading="lazy"
                  decoding="async"
                  sizes="(min-width: 1024px) 300px, (min-width: 768px) 45vw, 90vw"
                  class="rounded-lg object-cover w-full h-full"
                />
              </a>
            ) : (
              <Image
                alt={image.alt}
                src={image.src}
                width={500}
                height={500}
                loading="lazy"
                decoding="async"
                sizes="(min-width: 1024px) 300px, (min-width: 768px) 45vw, 90vw"
                class="rounded-lg object-cover w-full h-full"
              />
            )}
          </div>
        ))}
      </div>
    )
  }
</section>
