---
import Base from "../../layouts/Base.astro";

export const prerender = false;

const nextPath = Astro.url.searchParams.get("next")?.startsWith("/thesis")
  ? Astro.url.searchParams.get("next")
  : "/thesis";
const hasError = Astro.url.searchParams.get("error") === "1";
---

<Base title="Thesis Access" description="Enter password to access the private thesis">
  <section class="space-y-6">
    <div>
      <h1 class="title mb-2 font-medium text-2xl tracking-tight">Private Thesis</h1>
      <p class="text-neutral-600 dark:text-neutral-400">
        Enter your password to continue. Access lasts for 24 hours.
      </p>
    </div>

    <form method="post" action="/api/thesis-login" class="space-y-4 max-w-sm">
      <input type="hidden" name="next" value={nextPath ?? "/thesis"} />
      
      {hasError && (
        <div class="p-4 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded text-red-800 dark:text-red-200 text-sm">
          Incorrect password. Please try again.
        </div>
      )}

      <div class="space-y-2">
        <label for="password" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300">
          Password
        </label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="w-full px-4 py-2 border border-neutral-300 dark:border-neutral-600 rounded-md bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-600 transition-colors"
          placeholder="Enter password"
        />
      </div>

      <button
        type="submit"
        class="w-full px-4 py-2 bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 font-medium rounded-md hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-600"
      >
        Open Thesis
      </button>
    </form>
  </section>
</Base>
