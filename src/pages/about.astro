---
import Base from "../layouts/Base.astro";
import { socialLinks } from "../config";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";

const blogPosts = (await getCollection("blog")).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<Base>
  <section class="max-w-[720px] w-full mx-auto space-y-12">

    <!-- Profile Intro -->
    <div class="flex items-center gap-5">
      <Image
        src="/profile.webp"
        alt="Profile photo"
        class="w-24 h-24 rounded-full md:grayscale md:hover:grayscale-0"
        width={96}
        height={96}
      />
      <div>
        <h1 class="text-2xl font-bold text-black dark:text-white">
          👋 Hey, I'm Matin.
        </h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          Engineer. Systems Thinker. Occasional Photographer.
        </p>
      </div>
    </div>

    <!-- Bio -->
    <div class="text-base leading-relaxed text-black dark:text-white space-y-4">
      <p>
        I'm a <strong>Software Engineer</strong> pursuing my Master's in Computer Engineering at <a href="https://en.iyte.edu.tr/" class="underline hover:opacity-80">IZTECH</a>.
      </p>
      <p>
        For me, the best code is open, and the best ideas are shared. I'm deeply driven by the open-source philosophy and the energy of communities where cool people build things together.
      </p>
      <p>
        Think of this site as my digital garden. I use it to <a href="https://www.swyx.io/learn-in-public" class="underline hover:opacity-80">#learn-in-public</a>, documenting my experiments and sharing the fascinating ideas I've borrowed from others along the way. Alongside playing with bits and bytes, I'm usually out <a href="https://www.flickr.com/photos/chillmetin/" class="underline hover:opacity-80">capturing moments</a>.
      </p>
      <!-- <p>
        See what I'm up to <a href="/now" class="underline hover:opacity-80">/now</a>.
      </p> -->
    </div>

    <!-- Links -->
    <div>
      <p class="text-base text-black dark:text-white">
        See what I'm <a href="/now" class="underline hover:opacity-80">/now</a> up to, and what I <a href="/use" class="underline hover:opacity-80">/use</a>.
      </p>
    </div>

    <!-- Start Here -->
    <!-- <div>
      <h2 class="text-xl font-semibold tracking-wide uppercase text-neutral-600 dark:text-neutral-400 mb-3">
        Start Here
      </h2>
      <ul class="list-disc list-inside space-y-1 text-neutral-800 dark:text-neutral-200">
        <li><a href="/blog/why" class="text-blue-600 dark:text-blue-400 hover:underline">Why I Write →</a></li>

      </ul>
    </div> -->

    <!-- Latest Posts -->
    <!-- <div>
      <h2 class="text-xl font-semibold tracking-wide uppercase text-neutral-600 dark:text-neutral-400 mb-3">
        Latest Posts
      </h2>
      <ul class="space-y-4">
        {
          blogPosts.slice(0, 3).map(post => (
            <li>
              <a href={`/blog/${post.slug}`} class="text-lg font-medium text-neutral-800 dark:text-neutral-100 hover:underline">
                {post.data.title}
              </a>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">
                <FormattedDate date={post.data.publishedAt} />
              </div>
            </li>
          ))
        }
      </ul>
    </div> -->

    <!-- Outro -->
    <div class="pt-4 border-t border-neutral-300 dark:border-neutral-800 space-y-2">
      <p class="text-xs text-neutral-500 dark:text-neutral-600">
        <span><a href="/pgp-key.asc" class="underline hover:opacity-80">PGP</a>: <code class="font-mono">EA11 C2D1 3003 2BB9 BE6C B693 8E68 5FFA 61FF 5538</code> </span>
      </p>
    </div>

    
  </section>
</Base>
